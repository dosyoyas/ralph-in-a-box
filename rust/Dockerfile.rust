FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bc \
    build-essential \
    ca-certificates \
    curl \
    gh \
    git \
    jq \
    openssh-client \
    pkg-config \
    ripgrep \
    sudo \
    tmux \
    && rm -rf /var/lib/apt/lists/*

# Trust github.com SSH key for git over SSH
RUN mkdir -p -m 700 /root/.ssh \
    && ssh-keyscan -t ed25519 github.com >> /root/.ssh/known_hosts \
    && chmod 600 /root/.ssh/known_hosts

# Install beads CLI via npm
RUN npm install -g @beads/bd \
    && ln -sf /usr/local/bin/bd /usr/local/bin/beads \
    && bd --version

# Install Rust toolchain (stable) with clippy and rustfmt
ENV RUSTUP_HOME="/usr/local/rustup" \
    CARGO_HOME="/usr/local/cargo" \
    PATH="/usr/local/cargo/bin:${PATH}"

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- \
    -y --default-toolchain stable --profile default \
    && rustup component add clippy rustfmt \
    && cargo --version && rustc --version

# Install agent CLI (claude, cursor, or codex)
ARG AGENT=claude
RUN if [ "$AGENT" = "claude" ]; then \
        npm install -g @anthropic-ai/claude-code@2.1.50; \
    elif [ "$AGENT" = "cursor" ]; then \
        curl https://cursor.com/install -fsS | bash; \
    elif [ "$AGENT" = "codex" ]; then \
        npm install -g @openai/codex @fission-ai/openspec@latest; \
    fi

ENV PATH="/root/.local/bin:${PATH}"

COPY ralph-loop.sh /opt/ralph/ralph-loop.sh
COPY rust/DO_TASK_RUST.md /opt/ralph/DO_TASK.md
COPY BOOTSTRAP.md /opt/ralph/BOOTSTRAP.md
COPY VERIFY.md /opt/ralph/VERIFY.md

RUN chmod +x /opt/ralph/ralph-loop.sh

WORKDIR /workspace

ENTRYPOINT ["/opt/ralph/ralph-loop.sh"]
